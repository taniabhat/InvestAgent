# LLM Provider — pick one
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...

# Which provider to use: "openai" | "anthropic" | "groq" | "openrouter"
LLM_PROVIDER=openai

# Optional: override default model for your chosen provider
# LLM_MODEL=llama-3.3-70b-versatile


# Financial data (all free-tier, no key needed for Alpha Vantage demo key)
ALPHA_VANTAGE_KEY=demo
# Get a free key at https://www.alphavantage.co/support/#api-key

# Optional: News API (free tier)
# NEWS_API_KEY=your-key-here
# Get a free key at https://newsapi.org/

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=10
